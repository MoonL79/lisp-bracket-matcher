{
  "name": "lisp-bracket-matcher",
  "displayName": "Lisp Bracket Matcher",
  "description": "Custom bracket matching for Lisp/Scheme files that ignores escaped \\#( and \\#).",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:scheme",
    "onLanguage:racket",
    "onLanguage:lisp"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Lisp Bracket Matcher",
      "properties": {
        "lispBracketMatcher.enableDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Enable diagnostics for unbalanced parentheses in supported Lisp documents."
        },
        "lispBracketMatcher.debounceMs": {
          "type": "number",
          "default": 120,
          "minimum": 0,
          "description": "Delay in milliseconds before rescanning after document changes."
        }
      }
    },
    "configurationDefaults": {
      "[scheme]": {
        "editor.matchBrackets": "never"
      },
      "[racket]": {
        "editor.matchBrackets": "never"
      },
      "[lisp]": {
        "editor.matchBrackets": "never"
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
